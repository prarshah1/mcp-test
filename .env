# =============================================================================
# How to use (same variables as temp/mcp-fastapi-auth/.env.example — see that repo)
# =============================================================================
#
# Local:
#   cp .env.example .env
#   Edit .env — you must supply Scalekit credentials used by the auth middleware.
#
# Databricks App:
#   Set the same variable names in the app’s Environment / Secrets UI (not only .env).
#
# Minimum for Scalekit (SDK needs these three to validate Bearer tokens):
#   1) SCALEKIT_ENVIRONMENT_URL — your Scalekit workspace / issuer base URL
#   2) SCALEKIT_CLIENT_ID       — OAuth client id from Scalekit (MCP app / resource client)
#   3) SCALEKIT_CLIENT_SECRET   — OAuth client secret (never commit real values)
#
# Also required when auth is on: audience + metadata URL (see below).
# Upstream walkthrough: temp/mcp-fastapi-auth/readme.md (Scalekit dashboard → MCP server).
#
# =============================================================================

# --- Required when auth is enabled (AUTH_ENABLED=true, or both CLIENT_ID and SECRET set) ---

SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=

SCALEKIT_RESOURCE_METADATA_URL=
SCALEKIT_ENVIRONMENT_URL=

SCALEKIT_AUTHORIZATION_SERVERS=
SCALEKIT_RESOURCE_IDENTIFIER=
SCALEKIT_AUDIENCE_NAME=
SCALEKIT_RESOURCE_NAME=
SCALEKIT_RESOURCE_DOCS_URL=

# Full JSON for GET /.well-known/oauth-protected-resource/mcp (optional; overrides building from lines above)
# METADATA_JSON_RESPONSE=

# --- Optional ---

# AUTH_ENABLED=true

# SCALEKIT_TOOL_CALL_SCOPES=health:read
# OAUTH_SCOPES_SUPPORTED=health:read

# MY_NAME=

# PORT=8000
