# =============================================================================
# Databricks App (primary) — same names as temp/mcp-fastapi-auth/.env.example
# =============================================================================
#
# In Databricks: App → Environment / Secrets — set these for the deployed MCP app.
# Google / other IdPs: configure in Scalekit (Social connections), not in this repo.
#
# MCP is served at: https://<your-app-host>/mcp
# Metadata URL must be (note: NO /mcp/ before /.well-known):
#   https://<your-app-host>/.well-known/oauth-protected-resource/mcp
#
# =============================================================================

# --- Scalekit SDK (Bearer validation on /mcp) ---

SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=

SCALEKIT_ENVIRONMENT_URL=

# Full URL to protected-resource metadata (WWW-Authenticate); use your Databricks app host
# Example: https://abc123.aws.databricksapps.com/.well-known/oauth-protected-resource/mcp
SCALEKIT_RESOURCE_METADATA_URL=

SCALEKIT_AUTHORIZATION_SERVERS=
SCALEKIT_RESOURCE_IDENTIFIER=
SCALEKIT_AUDIENCE_NAME=
SCALEKIT_RESOURCE_NAME=
SCALEKIT_RESOURCE_DOCS_URL=

# Optional: full JSON for GET /.well-known/oauth-protected-resource/mcp
# METADATA_JSON_RESPONSE=

# --- Optional ---

# AUTH_ENABLED=true

# SCALEKIT_TOOL_CALL_SCOPES=search:read
# OAUTH_SCOPES_SUPPORTED=search:read

# MY_NAME=
